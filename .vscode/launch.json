{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Python: run module",
      "type": "debugpy",
      "request": "launch",
      "module": "cs336_basics.optimizer",
      "args": [],
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}",
      "justMyCode": false
    },
    {
      "name": "Debug pytest",
      "type": "debugpy",
      "request": "launch",
      "module": "pytest",
      "args": [
        "tests/test_data.py",
        "-s"
      ],
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}",
      "justMyCode": false,
      "subProcess": true
    },
    {
      "name": "Attach to debugpy 5678",
      "type": "debugpy",
      "request": "attach",
      "connect": {
        "host": "localhost",
        "port": 5678
      },
      "justMyCode": false,
      "subProcess": true
    }
  ]
}
