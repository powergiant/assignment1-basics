{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug pytest: test_train_bpe",
      "type": "debugpy",
      "request": "launch",
      "module": "pytest",
      "args": [
        "tests/test_train_bpe.py",
        "-s"
      ],
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}",
      "justMyCode": false,
      "subProcess": true
    },
    {
      "name": "Attach to debugpy 5678",
      "type": "debugpy",
      "request": "attach",
      "connect": {
        "host": "localhost",
        "port": 5678
      },
      "justMyCode": false,
      "subProcess": true
    }
  ]
}
